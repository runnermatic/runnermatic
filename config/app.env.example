# config/app.env.example
# Copy to config/app.env and fill in real values. Do NOT commit secrets.

# GitHub org / API basics
GITHUB_ORG=runnermatic
GITHUB_BASE_URL=https://github.com
GITHUB_API_URL=https://api.github.com

# GitHub App identity
# App name is just for reference; ID and installation ID are what matter.
GITHUB_APP_NAME=runnermatic-tokenizer
GITHUB_APP_ID=3000962          # numeric App ID from the App settings page
GITHUB_APP_INSTALLATION_ID=113834709  # from the installations URL

# Path inside the sandbox to the downloaded PEM file, e.g. /secrets/runnermatic-tokenizer.pem
GITHUB_APP_PRIVATE_KEY_PATH=/home/mike/runnermatic/config/runnermatic-tokenizer.pem
