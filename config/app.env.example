# config/app.env.example
# Copy to config/app.env and fill in values. Not committed (in .gitignore).

GITHUB_ORG=your-org-name
GITHUB_BASE_URL=https://github.com
GITHUB_API_URL=https://api.github.com

# GitHub App identity (from App settings page and installation URL)
GITHUB_APP_NAME=your-app-name
GITHUB_APP_ID=             # numeric App ID
GITHUB_APP_INSTALLATION_ID= # numeric Installation ID

# Absolute path to the App's PEM private key
GITHUB_APP_PRIVATE_KEY_PATH=/path/to/your-app.pem
