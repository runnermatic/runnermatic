# config/org.env.example
# Copy to config/org.env and fill in real values. Do NOT commit org.env.

# GitHub org / API basics
GITHUB_ORG=runnermatic
GITHUB_BASE_URL=https://github.com
GITHUB_API_URL=https://api.github.com

# Personal access token for bootstrap runner registration.
# Must have admin permissions for the Runnermatic org.
GITHUB_PAT=<paste your fine-grained PAT here>
