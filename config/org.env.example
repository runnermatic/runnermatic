# config/org.env.example
# Copy to config/org.env and fill in values. Not committed (in .gitignore).

GITHUB_ORG=your-org-name
GITHUB_BASE_URL=https://github.com
GITHUB_API_URL=https://api.github.com

# Fine-grained PAT (optional — only needed for bootstrap or gh CLI convenience).
# Required permissions: Self-hosted runners R/W, Contents R/W, Actions R/W, Workflows R/W.
GITHUB_PAT=
